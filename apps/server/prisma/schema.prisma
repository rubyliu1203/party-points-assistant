  partyMemberId Int
  quarterId     Int
  year          Int
  month         Int

  baseScore     Float
  baseBonus     Float
  taskBonus     Float
  deduction     Float
  monthlyTotal  Float?

  remark        String?
  archivedAt    DateTime @default(now())

  @@unique([partyMemberId, quarterId, year, month])
